@startuml
title Diagrama de Interacción - Descarga de archivo (UP Archivos)
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
autonumber
actor "Usuario\nAutorizado" as u
participant "Aplicación\nWeb" as web
participant "Controlador\nArchivos" as ctrl
participant "Gestión\nArchivos" as facade
participant "Repositorio\nProxy" as repo
participant "Grilla\nDatos" as grid
participant "Data\nReader" as reader
participant "Object\nStorage" as s3

u -> web: solicita descarga
activate web
web -> ctrl: GET /archivos/{id}
activate ctrl
ctrl -> facade: obtenerArchivo(id, usuario)
activate facade
facade -> repo: findByIdConPermisos(id, usuario)
activate repo
repo -> grid: get(metadata)
activate grid

alt [metadata no existe en cache]
  grid -> reader: solicitarCarga(id)
  activate reader
  reader --> grid: recargar metadata
  deactivate reader
else [metadata existe en cache]
  grid --> repo: metadata
end

grid --> repo: metadata disponible
deactivate grid
repo --> facade: Archivo autorizado
deactivate repo
facade -> s3: generarUrlFirmada(objectKey)
activate s3
s3 --> facade: urlDescarga
deactivate s3
facade --> ctrl: ArchivoDTO(id, nombre, urlDescarga)
deactivate facade
ctrl --> web: respuesta 200 + DTO
deactivate ctrl
web --> u: muestra enlace de descarga
deactivate web
note right of reader
El cache miss se resuelve vía Data Reader,
no por acceso directo de la UP a PostgreSQL.
end note
@enduml
